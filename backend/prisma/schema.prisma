generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// USERS
// ==========================================
model User {
  id            BigInt    @id @default(autoincrement())
  name          String?   @db.VarChar(120)
  avatarUrl     String?   @map("avatar_url") @db.Text
  role          Role      @default(USER)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  authMethods   UserAuth[]
  addresses     Address[]
  cartItems     CartItem[]
  orders        Order[]
  reviews       Review[]
  formSubmissions FormSubmission[]
  events        Event[]
  auditLogs     AuditLog[]

  @@map("users")
}

// ==========================================
// USER AUTH (Multi-auth support)
// ==========================================
model UserAuth {
  id            BigInt    @id @default(autoincrement())
  userId        BigInt    @map("user_id")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  authType      AuthType  @map("auth_type")
  identifier    String    @db.VarChar(255)
  credential    String?   @db.Text
  isVerified    Boolean   @default(false) @map("is_verified")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([authType, identifier])
  @@index([userId])
  @@map("user_auth")
}

// ==========================================
// OTP VERIFICATIONS
// ==========================================
model OtpVerification {
  id            BigInt    @id @default(autoincrement())
  identifier    String    @db.VarChar(255)
  otpCode       String    @map("otp_code") @db.VarChar(255)
  expiresAt     DateTime  @map("expires_at")
  isUsed        Boolean   @default(false) @map("is_used")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("otp_verifications")
}

enum Role {
  USER
  ADMIN
  MANAGER
}

enum AuthType {
  EMAIL
  PHONE
  GOOGLE
}

// ==========================================
// CATEGORIES
// ==========================================
model Category {
  id            BigInt    @id @default(autoincrement())
  name          String    @db.VarChar(150)
  slug          String    @unique @db.VarChar(160)
  description   String?   @db.Text
  cardImage     String?   @map("card_image") @db.Text
  bannerImage   String?   @map("banner_image") @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  parentId      BigInt?   @map("parent_id")
  parent        Category? @relation("CategoryParent", fields: [parentId], references: [id], onDelete: SetNull)
  children      Category[] @relation("CategoryParent")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  products      ProductCategory[]

  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("categories")
}

// ==========================================
// PRODUCTS (Color Variant Level)
// ==========================================
model Product {
  id            BigInt    @id @default(autoincrement())
  name          String    @db.VarChar(255)
  slug          String    @unique @db.VarChar(255)
  colorName     String    @map("color_name") @db.VarChar(100)
  colorCode     String?   @map("color_code") @db.VarChar(20)
  gender        String?   @db.VarChar(20)
  description   String?   @db.Text
  bulletPoints  Json?     @map("bullet_points")
  extraData     Json?     @map("extra_data")
  isActive      Boolean   @default(true) @map("is_active")
  sortOrder     Int       @default(0) @map("sort_order")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  categories    ProductCategory[]
  images        ProductImage[]
  listings      Listing[]
  reviews       Review[]

  @@index([isActive])
  @@index([slug])
  @@index([sortOrder])
  @@map("products")
}

model ProductImage {
  id          BigInt   @id @default(autoincrement())
  productId   BigInt   @map("product_id")
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageUrl    String   @map("image_url") @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([sortOrder])
  @@map("product_images")
}

model ProductCategory {
  productId   BigInt   @map("product_id")
  categoryId  BigInt   @map("category_id")

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([productId, categoryId])
  @@index([productId])
  @@index([categoryId])
  @@map("product_categories")
}

// ==========================================
// LISTINGS (Size Level Sellable)
// ==========================================
model Listing {
  id              BigInt    @id @default(autoincrement())
  productId       BigInt    @map("product_id")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  size            String?   @db.VarChar(50)
  skuCode         String?   @unique @map("sku") @db.VarChar(120)
  price           Decimal   @db.Decimal(12, 2)
  discountAmount  Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  stock           Int       @default(0)
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  cartItems       CartItem[]
  orderItems      OrderItem[]

  @@index([productId])
  @@index([isActive])
  @@map("listings")
}

// ==========================================
// ADDRESSES
// ==========================================
model Address {
  id          BigInt    @id @default(autoincrement())
  userId      BigInt    @map("user_id")
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  fullName    String    @map("full_name") @db.VarChar(120)
  phone       String    @db.VarChar(15)
  line1       String    @db.Text
  line2       String?   @db.Text
  landmark    String?   @db.Text
  city        String    @db.VarChar(120)
  state       String    @db.VarChar(120)
  pincode     String    @db.VarChar(20)
  country     String    @default("India") @db.VarChar(80)
  isDefault   Boolean   @default(false) @map("is_default")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([userId])
  @@map("addresses")
}

// ==========================================
// CART
// ==========================================
model CartItem {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt   @map("user_id")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  listingId   BigInt   @map("listing_id")
  listing     Listing  @relation(fields: [listingId], references: [id])

  quantity    Int
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, listingId])
  @@index([listingId])
  @@map("cart_items")
}

// ==========================================
// ORDERS
// ==========================================
model Order {
  id              BigInt      @id @default(autoincrement())
  orderNumber     String      @unique @map("order_number") @db.VarChar(40)
  userId          BigInt      @map("user_id")
  user            User        @relation(fields: [userId], references: [id])

  subtotal        Decimal     @db.Decimal(12, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(12, 2)
  deliveryCharge  Decimal     @default(0) @map("delivery_charge") @db.Decimal(12, 2)
  totalAmount     Decimal     @map("total_amount") @db.Decimal(12, 2)

  paymentStatus   PaymentStatus @default(PENDING) @map("payment_status")
  orderStatus     OrderStatus   @default(PENDING) @map("order_status")

  addressSnapshot Json        @map("address_snapshot")

  placedAt        DateTime?   @map("placed_at")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  items           OrderItem[]
  payments        Payment[]
  shipments       Shipment[]

  @@index([userId])
  @@index([orderStatus])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id                BigInt    @id @default(autoincrement())
  orderId           BigInt    @map("order_id")
  order             Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  listingId         BigInt    @map("listing_id")
  listing           Listing   @relation(fields: [listingId], references: [id])

  productSnapshot   Json      @map("product_snapshot")

  unitPrice         Decimal   @map("unit_price") @db.Decimal(12, 2)
  discountAmount    Decimal   @default(0) @map("discount_amount") @db.Decimal(12, 2)
  finalUnitPrice    Decimal   @map("final_unit_price") @db.Decimal(12, 2)

  quantity          Int
  totalAmount       Decimal   @map("total_amount") @db.Decimal(12, 2)

  createdAt         DateTime  @default(now()) @map("created_at")

  @@index([orderId])
  @@index([listingId])
  @@map("order_items")
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  CREATED
  SUCCESS
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

// ==========================================
// PAYMENTS (Multi-Payment Support)
// ==========================================
model Payment {
  id                  BigInt        @id @default(autoincrement())

  orderId             BigInt        @map("order_id")
  order               Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider            String        @db.VarChar(50)
  providerOrderId     String?       @map("provider_order_id") @db.VarChar(255)
  providerPaymentId   String?       @map("provider_payment_id") @db.VarChar(255)
  providerSignature   String?       @map("provider_signature") @db.Text

  amount              Decimal       @db.Decimal(12, 2)
  currency            String        @default("INR") @db.VarChar(10)

  status              PaymentStatus @default(CREATED)

  rawResponse         Json?         @map("raw_response")

  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([providerPaymentId])
  @@index([status])
  @@map("payments")
}

// ==========================================
// SHIPMENTS (Multi-Shipping Support)
// ==========================================
model Shipment {
  id                  BigInt    @id @default(autoincrement())

  orderId             BigInt    @map("order_id")
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)

  provider            String    @db.VarChar(50)
  providerOrderId     String?   @map("provider_order_id") @db.VarChar(255)
  trackingId          String?   @map("tracking_id") @db.VarChar(255)
  trackingUrl         String?   @map("tracking_url") @db.Text

  shipmentStatus      String    @default("CREATED") @map("shipment_status") @db.VarChar(50)

  rawResponse         Json?     @map("raw_response")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  @@index([orderId])
  @@index([trackingId])
  @@index([shipmentStatus])
  @@map("shipments")
}

// ==========================================
// REVIEWS (Verified Purchase)
// ==========================================
model Review {
  id              BigInt    @id @default(autoincrement())
  productId       BigInt    @map("product_id")
  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  userId          BigInt    @map("user_id")
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderId         BigInt    @map("order_id")

  rating          Int
  title           String?   @db.VarChar(255)
  comment         String?   @db.Text
  images          Json?     // Array of image URLs
  isVerified      Boolean   @default(false) @map("is_verified")
  isHelpful       Int       @default(0) @map("is_helpful")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@unique([productId, userId, orderId])
  @@index([productId])
  @@index([userId])
  @@index([orderId])
  @@index([isVerified])
  @@map("reviews")
}

// ==========================================
// COUPON SYSTEM
// ==========================================
model Coupon {
  id                BigInt        @id @default(autoincrement())
  code              String        @unique @db.VarChar(50)
  discountType      DiscountType  @map("discount_type")
  discountValue     Decimal       @map("discount_value") @db.Decimal(10, 2)
  maxDiscount       Decimal?      @map("max_discount") @db.Decimal(10, 2)
  minOrderAmount    Decimal?      @map("min_order_amount") @db.Decimal(10, 2)
  usageLimit        Int?          @map("usage_limit")
  usageCount        Int           @default(0) @map("usage_count")
  expiresAt         DateTime?     @map("expires_at")
  isActive          Boolean       @default(true) @map("is_active")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  @@map("coupons")
}

enum DiscountType {
  PERCENT
  FLAT
}

// ==========================================
// ANALYTICS
// ==========================================
model Visit {
  id          BigInt   @id @default(autoincrement())
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  path        String?  @db.Text
  referrer    String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([path])
  @@map("visits")
}

model Event {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventType   String   @map("event_type") @db.VarChar(100)
  entityType  String?  @map("entity_type") @db.VarChar(100)
  entityId    BigInt?  @map("entity_id")
  meta        Json?
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
  @@map("events")
}

// ==========================================
// DYNAMIC FORM SYSTEM
// ==========================================
model Form {
  id              BigInt       @id @default(autoincrement())
  name            String       @db.VarChar(120)
  slug            String       @unique @db.VarChar(160)
  description     String?      @db.Text
  isActive        Boolean      @default(true) @map("is_active")
  submitText      String?      @default("Submit") @map("submit_text") @db.VarChar(50)
  successMessage  String?      @map("success_message") @db.Text
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  fields          FormField[]
  submissions     FormSubmission[]

  @@map("forms")
}

model FormField {
  id            BigInt       @id @default(autoincrement())
  formId        BigInt       @map("form_id")
  form          Form         @relation(fields: [formId], references: [id], onDelete: Cascade)
  label         String       @db.VarChar(255)
  fieldKey      String       @map("field_key") @db.VarChar(100)
  fieldType     FieldType    @map("field_type")
  isRequired    Boolean      @default(false) @map("is_required")
  placeholder   String?      @db.VarChar(255)
  helpText      String?      @map("help_text") @db.Text
  options       Json?
  validation    Json?
  defaultValue  String?      @map("default_value") @db.Text
  sortOrder     Int          @default(0) @map("sort_order")
  createdAt     DateTime     @default(now()) @map("created_at")

  @@unique([formId, fieldKey])
  @@index([formId])
  @@map("form_fields")
}

model FormSubmission {
  id          BigInt   @id @default(autoincrement())
  formId      BigInt   @map("form_id")
  form        Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  userId      BigInt?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  data        Json
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([formId])
  @@index([userId])
  @@index([createdAt])
  @@map("form_submissions")
}

enum FieldType {
  TEXT
  EMAIL
  PHONE
  NUMBER
  TEXTAREA
  SELECT
  RADIO
  CHECKBOX
  DATE
  FILE
  HIDDEN
}

// ==========================================
// SETTINGS
// ==========================================
model Setting {
  id            BigInt   @id @default(autoincrement())
  key           String   @unique @db.VarChar(100)
  value         String   @db.Text
  type          String   @default("string") @db.VarChar(20)
  description   String?  @db.Text
  isPublic      Boolean  @default(false) @map("is_public")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

// ==========================================
// AUDIT LOGS
// ==========================================
model AuditLog {
  id          BigInt   @id @default(autoincrement())
  userId      BigInt?  @map("user_id")
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action      String   @db.VarChar(255)
  entityType  String   @map("entity_type") @db.VarChar(100)
  entityId    BigInt?  @map("entity_id")
  oldValues   Json?    @map("old_values")
  newValues   Json?    @map("new_values")
  ipAddress   String?  @map("ip_address") @db.VarChar(45)
  userAgent   String?  @map("user_agent") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}
